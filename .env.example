# Project Bonsai Telegram bot config. Copy to .env or run scripts/set-bonsai-bot-env.sh.
# Do not commit real values.
BONSAI_TELEGRAM_BOT_TOKEN=
BONSAI_TELEGRAM_ALLOWED_USER_ID=
BONSAI_HUB_BASE_URL=http://10.0.0.38:5000
BONSAI_PI_SSH_TARGET=madmaestro@10.0.0.38
# Optional extra SSH flags, e.g. -i /Users/rivet/.ssh/id_ed25519
BONSAI_PI_SSH_EXTRA_ARGS=
BONSAI_HTTP_TIMEOUT_SECONDS=8
